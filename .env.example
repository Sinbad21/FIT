# Copia in .env.local e compila.

# --- AI provider (opzionale; fallback rule-based sempre attivo) ---
# Configurabile anche dall'app in Profilo -> Assistente AI (ha priorità su questi valori).
AI_PROVIDER=none            # none | openai | local
AI_API_KEY=                 # chiave provider (per openai)
AI_MODEL=gpt-4o-mini        # modello
# AI_BASE_URL=http://localhost:11434/v1   # per provider locale OpenAI-compatibile

# --- Web Push (opzionale) ---
# Genera con: npm run vapid:generate
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# --- Database (opzionale) ---
# FITCONTROL_DB_PATH=/percorso/personalizzato/fitcontrol.sqlite

# --- Lock PIN locale (opzionale, vedi sicurezza) ---
# NEXT_PUBLIC_APP_PIN=
